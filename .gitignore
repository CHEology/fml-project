# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — download instructions in data/README.md
data/raw/*
data/processed/*
data/eval/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/eval/.gitkeep
!data/external/.gitkeep
*.csv
*.parquet
*.json.gz

# Models — too large for git
models/*
!models/.gitkeep
*.pt
*.pth
*.index
*.bin
*.ckpt
*.pkl
*.npy
*.scaler.json
*.features.json

# Test fixtures — small synthetic artifacts that ARE checked in
!tests/fixtures/
!tests/fixtures/**

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Tooling caches and assistant scratch space
.claude/
.ruff_cache/
.pytest_cache/
.pytest_tmp/
.tmp_pytest/
.tmp_smoke/
.tmp_pytest_run/
pytesttmp/
manual_tmp_dir/
.tmp_check/
